## Frontend / Next.js
NEXT_PUBLIC_BACKEND_URL=http://localhost:5000

## Gemini chat (required only for chat feature)
GOOGLE_GENERATIVE_AI_API_KEY=
FLASK_API_URL=http://127.0.0.1:5000

## Optional Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Optional alternative key name supported by app/lib/supabase.ts
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=

## Backend / Flask
PORT=5000

## Optional Planner integration
ENABLE_PLANNER_INTEGRATION=false
PLANNER_API_BASE_URL=
PLANNER_EMAIL=
PLANNER_PASSWORD=
PLANNER_DEFAULT_PROJECT_ID=1
